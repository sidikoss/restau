{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/:path*.(css|js|png|jpg|jpeg|gif|ico|svg|webp|json|xml)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    { "source": "/menu", "destination": "/Menu.html", "permanent": true },
    { "source": "/reservation", "destination": "/reserve.html", "permanent": true },
    { "source": "/commander", "destination": "/order.html", "permanent": true },
    { "source": "/a-propos", "destination": "/about.html", "permanent": true },
    { "source": "/contact", "destination": "/contact.html", "permanent": true },
    { "source": "/mentions-legales", "destination": "/mentions-legales.html", "permanent": true },
    { "source": "/cgu", "destination": "/cgu.html", "permanent": true },
    { "source": "/blog", "destination": "/blog.html", "permanent": true },
    { "source": "/recrutement", "destination": "/recrutement.html", "permanent": true }
  ]
}
